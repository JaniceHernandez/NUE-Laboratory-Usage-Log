
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system (Professor or Admin).",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's institutional email."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "professor"],
          "description": "The role assigned to the user."
        },
        "status": {
          "type": "string",
          "enum": ["active", "blocked"],
          "description": "The current account status."
        },
        "college": {
          "type": "string",
          "description": "Primary institutional college affiliation."
        },
        "name": {
          "type": "string",
          "description": "Display name from Google profile."
        },
        "photoURL": {
          "type": "string",
          "description": "Profile picture URL."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "AuthorizedAdmin": {
      "title": "Authorized Admin",
      "description": "A registry of emails authorized for administrative access.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "authorizedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Session": {
      "title": "Session",
      "description": "Represents a laboratory usage session.",
      "type": "object",
      "properties": {
        "professorEmail": { "type": "string" },
        "roomNumber": { "type": "string" },
        "college": { "type": "string" },
        "program": { "type": "string" },
        "section": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["professorEmail", "roomNumber", "status", "startTime"]
    },
    "Room": {
      "title": "Room",
      "description": "Represents a laboratory room.",
      "type": "object",
      "properties": {
        "number": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "inactive", "maintenance"] },
        "currentlyOccupied": { "type": "boolean", "description": "Whether a session is currently active in this room." },
        "usageCount": { "type": "number" }
      },
      "required": ["number", "location", "status"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of authorized users and their roles."
    },
    "/authorizedAdmins/{emailId}": {
      "schema": "AuthorizedAdmin",
      "description": "Registry of pre-authorized administrative emails."
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Collection of laboratory usage sessions."
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Collection of laboratory rooms managed by the system."
    }
  }
}
