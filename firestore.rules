rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper to get user data from the users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper to check for specific role
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Helper to check if account is active
    function isActive() {
      return isSignedIn() && getUserData().status == 'active';
    }

    // Users collection rules
    match /users/{userId} {
      // Users can only read their own profile, Admins can read all
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      // Allow creation during signup
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Only admins can update status/role, users can update their own non-sensitive fields
      allow update: if hasRole('admin') || (request.auth.uid == userId && isActive());
    }
    
    // Sessions collection rules
    match /sessions/{sessionId} {
      // Admins read all; Professors read only their own
      allow read: if isSignedIn() && (
        hasRole('admin') || 
        (resource != null && resource.data.professorEmail == request.auth.token.email) ||
        (resource == null) // allow query initialization
      );
      
      // Professors can create sessions for themselves if active
      allow create: if isSignedIn() && isActive() && (
        request.resource.data.professorEmail == request.auth.token.email
      );
      
      // Professors can update their own active sessions
      allow update: if isSignedIn() && isActive() && (
        resource.data.professorEmail == request.auth.token.email
      );
      
      // Only admins can delete logs
      allow delete: if hasRole('admin');
    }

    // Rooms collection rules
    match /rooms/{roomId} {
      // All signed-in users can see room availability
      allow read: if isSignedIn();
      // Only admins can manage the room list
      allow write: if hasRole('admin');
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}