rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic sign-in check
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Safely check for a role without failing if the user document is missing
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Check if account is active
    function isActive() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      // Admins can create and manage user records (for invitations/blocking)
      allow create: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow update: if hasRole('admin') || (request.auth.uid == userId);
      allow delete: if hasRole('admin');
    }
    
    // Sessions collection rules
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (
        hasRole('admin') || 
        resource.data.professorEmail == request.auth.token.email ||
        resource.data.status == 'active'
      );
      
      allow create: if isSignedIn() && (
        request.resource.data.professorEmail == request.auth.token.email
      );
      
      allow update: if isSignedIn() && (
        resource.data.professorEmail == request.auth.token.email || hasRole('admin')
      );
      
      allow delete: if hasRole('admin');
    }

    // Rooms collection rules
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create, delete: if hasRole('admin');
      allow update: if hasRole('admin') || (
        isActive() && 
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['currentlyOccupied', 'usageCount'])
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}