rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic sign-in check
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Identify the Super Admin
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@neu.edu.ph';
    }

    // Safely check for a role or Super Admin status
    function hasRole(role) {
      return isSignedIn() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role)
      );
    }

    // Check if account is active
    function isActive() {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active')
      );
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow update: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isSuperAdmin();
    }
    
    // Authorized Admins registry (Pre-authorization)
    match /authorizedAdmins/{emailId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Sessions collection rules
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (
        hasRole('admin') || 
        resource.data.professorEmail == request.auth.token.email
      );
      
      allow create: if isSignedIn();
      
      allow update: if hasRole('admin') || (
        isSignedIn() && resource.data.professorEmail == request.auth.token.email
      );
      
      allow delete: if hasRole('admin');
    }

    // Rooms collection rules
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create, delete: if hasRole('admin');
      allow update: if hasRole('admin') || (
        isActive() && 
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['currentlyOccupied', 'usageCount'])
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}