
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper to check for specific role
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Helper to check if account is active
    function isActive() {
      return isSignedIn() && getUserData().status == 'active';
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow update: if hasRole('admin') || (request.auth.uid == userId && isActive());
    }
    
    // Sessions collection rules
    match /sessions/{sessionId} {
      allow read: if hasRole('admin') || (isSignedIn() && request.auth.token.email == resource.data.professorEmail);
      allow create: if isSignedIn() && isActive() && request.resource.data.professorEmail == request.auth.token.email;
      allow update: if isSignedIn() && isActive() && resource.data.professorEmail == request.auth.token.email;
    }

    // Rooms collection rules
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
