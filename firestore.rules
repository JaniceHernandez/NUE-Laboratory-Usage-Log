rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic sign-in check
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Safely check for a role without failing if the user document is missing
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Check if account is active
    function isActive() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if hasRole('admin') || (request.auth.uid == userId && isActive());
    }
    
    // Sessions collection rules
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (
        hasRole('admin') || 
        (resource != null && resource.data.professorEmail == request.auth.token.email) ||
        (resource == null) // Allow query initiation
      );
      
      allow create: if isSignedIn() && (
        request.resource.data.professorEmail == request.auth.token.email
      );
      
      allow update: if isSignedIn() && (
        resource.data.professorEmail == request.auth.token.email || hasRole('admin')
      );
      
      allow delete: if hasRole('admin');
    }

    // Rooms collection rules
    match /rooms/{roomId} {
      // All signed-in users can see room availability
      allow read: if isSignedIn();
      // Only admins can manage the room list
      allow write: if hasRole('admin');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}